#!/bin/bash
# Pre-commit hook: cargo clippy, cargo audit, cargo bless
# Install: cp .githooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# Or:      git config core.hooksPath .githooks

set -e

echo "[pre-commit] Running checks..."

# 1. Cargo clippy (warnings as errors for commit gate)
echo ""
echo "=== cargo clippy ==="
if ! cargo clippy --release -- -D warnings 2>&1; then
    echo ""
    echo "[BLOCKED] clippy found warnings. Fix them before committing."
    exit 1
fi
echo "[OK] clippy clean"

# 2. Cargo audit (advisory DB check)
echo ""
echo "=== cargo audit ==="
if command -v cargo-audit &>/dev/null; then
    if ! cargo audit 2>&1; then
        echo ""
        echo "[WARNING] cargo audit found issues (not blocking commit)"
    else
        echo "[OK] no known vulnerabilities"
    fi
else
    echo "[SKIP] cargo-audit not installed (cargo install cargo-audit)"
fi
echo ""
echo "[pre-commit] All checks passed."
